{
  "name": "anderson-loyalty-app",
  "private": true,
  "version": "0.1.0",
  "description": "Telegram Mini App - Anderson Loyalty Program",
  "scripts": {
    "dev:api": "pnpm --filter @anderson/api dev",
    "dev:bot": "pnpm --filter @anderson/bot dev",
    "dev:webapp": "pnpm --filter @anderson/webapp dev",
    "dev": "pnpm --parallel --filter @anderson/api --filter @anderson/bot --filter @anderson/webapp run dev",
    "dev:admin": "pnpm --filter @anderson/admin dev",
    "build": "pnpm run --filter @anderson/shared build && pnpm run --parallel --filter @anderson/api --filter @anderson/bot --filter @anderson/webapp --filter @anderson/admin build",
    "lint": "pnpm run --recursive lint",
    "db:generate": "pnpm --filter @anderson/api prisma generate",
    "db:migrate": "pnpm --filter @anderson/api prisma migrate dev",
    "db:push": "pnpm --filter @anderson/api prisma db push"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "prisma": "6.19.2"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  }
}
